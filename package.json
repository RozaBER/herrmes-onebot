{
  "name": "@kirigaya/hermes-onebot",
  "version": "1.1.1",
  "description": "OneBot v11 protocol channel plugin for Hermes/OpenClaw (QQ/Lagrange.Core/go-cqhttp)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "LSTM-Kirigaya",
  "repository": {
    "type": "git",
    "url": "https://github.com/LSTM-Kirigaya/herrmes-onebot.git"
  },
  "bugs": {
    "url": "https://github.com/LSTM-Kirigaya/herrmes-onebot/issues"
  },
  "homepage": "https://github.com/LSTM-Kirigaya/herrmes-onebot#readme",
  "keywords": [
    "chatbot",
    "cqhttp",
    "hermes",
    "lagrange",
    "onebot",
    "openclaw",
    "qq"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "themes",
    "skills",
    "openclaw.plugin.json",
    "README.md",
    "hermes.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "skills/onebot-ops",
      "skills/onebot-scripts"
    ],
    "channel": {
      "id": "onebot",
      "label": "OneBot",
      "selectionLabel": "OneBot (QQ/Lagrange)",
      "docsPath": "/channels/onebot",
      "blurb": "OneBot v11 protocol via WebSocket (go-cqhttp, Lagrange.Core, etc.)",
      "order": 85,
      "aliases": [
        "qq",
        "lagrange",
        "cqhttp"
      ]
    }
  },
  "scripts": {
    "openclaw": "openclaw",
    "build": "tsc",
    "test:connect": "npx tsx scripts/test-connect.ts",
    "test:group-welcome": "npx tsx scripts/test-group-welcome.ts",
    "test:group-increase-handler": "npx tsx scripts/test-group-increase-handler.ts",
    "test:render-og-image": "npx tsx test/render-og-image.ts",
    "prepublishOnly": "npm run build",
    "pub": "npm run build && npm publish",
    "hermes": "hermes"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "cron": "^4.4.0",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.10.0",
    "marked": "^15.0.0",
    "puppeteer-core": "^24.39.1",
    "tsx": "^4.0.0",
    "ws": "^8.17.0"
  },
  "optionalDependencies": {
    "satori": "^0.12.0",
    "sharp": "^0.33.0"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "hermes": "*"
  },
  "peerDependenciesMeta": {
    "clawdbot": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    },
    "hermes": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  },
  "hermes": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "skills/onebot-ops",
      "skills/onebot-scripts"
    ],
    "channel": {
      "id": "onebot",
      "label": "OneBot",
      "selectionLabel": "OneBot (QQ/Lagrange)",
      "docsPath": "/channels/onebot",
      "blurb": "OneBot v11 protocol via WebSocket (go-cqhttp, Lagrange.Core, etc.)",
      "order": 85,
      "aliases": [
        "qq",
        "lagrange",
        "cqhttp"
      ]
    }
  }
}
